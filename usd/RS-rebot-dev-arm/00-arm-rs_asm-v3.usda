#usda 1.0
(
    "re-export 2026-07-17b: urdf-usd-converter 0.3.0 @554f3dc, masses PR#3 + inertia rescale"
    customLayerData = {
        string creator = "URDF USD Converter v0.3.0"
    }
    defaultPrim = "tn__00armrs_asmv3_hJ6D"
    doc = """Generated from Composed Stage of root layer urdf/00-arm-rs_asm-v3 (asset transformer, Isaac Sim Structure)


Generated from Composed Stage of root layer urdf/00-arm-rs_asm-v3 (asset transformer, Isaac Sim Structure)
"""
    kilogramsPerUnit = 1
    metersPerUnit = 1
    upAxis = "Z"
)

def PhysicsScene "PhysicsScene" (
    "Explicit gravity so non-Newton engines (PhysX) get a valid field. Without these, PhysX reads an undefined/degenerate gravity (observed as magnitude = -inf with direction (0,0,0)), which sends every rigid body tunnelling through the ground on the first step. Newton derives gravity from NewtonSceneAPI defaults, but PhysX needs the standard USD Physics attributes set here. -Z, 9.81 m/s^2 matches the MuJoCo/Newton parity."
    prepend apiSchemas = ["NewtonSceneAPI", "MjcSceneAPI"]
)
{
    vector3f physics:gravityDirection = (0, 0, -1)
    float physics:gravityMagnitude = 9.81
}

def Xform "tn__00armrs_asmv3_hJ6D" (
    prepend references = @./payloads/base.usda@
    variants = {
        string Physics = "physics"
    }
    append variantSets = "Physics"
)
{
    variantSet "Physics" = {
        "mujoco" (
            "Composes identically to Physics=physics; see the layer doc in payloads/Physics/mujoco.usda."
            prepend payload = @./payloads/Physics/mujoco.usda@
        ) {

        }
        "none" {

        }
        "physics" (
            prepend payload = @./payloads/Physics/physics.usda@
        ) {

        }
    }
}

